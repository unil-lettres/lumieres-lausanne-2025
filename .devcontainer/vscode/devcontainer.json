// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Lumières Lausanne — Python 3.13 / Django 5.2 (VSCode)",
	"dockerComposeFile": [
		"docker-compose.dev.yml",
		"../../docker-compose.yml"
	],
	"service": "devcontainer",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": { "moby": false },
		"ghcr.io/devcontainers/features/node:1": {}
	},
	"forwardPorts": [
		"phpmyadmin:80"
	],
	"runServices": [
		"devcontainer",
		"db",
		"solr",
		"phpmyadmin"
	],
	"initializeCommand": "make dev/init",
	"postCreateCommand": "make dev/install",
	"customizations": {
		"vscode": {
			"settings": {
				"[python]": {
					"editor.defaultFormatter": "ms-python.black-formatter",
					"editor.formatOnSave": false,
					"editor.codeActionsOnSave": {
						"source.organizeImports": "explicit"
					},
					"editor.rulers": [
						119
					]
				},
				"isort.args": [
					"--profile",
					"black"
				],
				"flake8.args": [
					"--max-line-length=119"
				]
			},
			"extensions": [
				"batisteo.vscode-django",
				"docker.docker",
				"junstyle.vscode-django-support",
				"ms-azuretools.vscode-docker",
				"ms-python.autopep8",
				"ms-python.black-formatter",
				"ms-python.debugpy",
				"ms-python.flake8",
				"ms-python.isort",
				"ms-python.mypy-type-checker",
				"ms-python.vscode-pylance",
				"nwgh.bandit",
				"tamasfe.even-better-toml",
				"Gruntfuggly.todo-tree"
			]
		}
	}
}
